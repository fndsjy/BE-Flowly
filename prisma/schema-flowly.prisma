generator client {
  provider = "prisma-client-js"
  output   = "../dist/generated/flowly"
}

generator clientSrc {
  provider = "prisma-client-js"
  output   = "../src/generated/flowly"
}

datasource db {
  provider = "sqlserver"
  url      = env("FLOWLY_DATABASE_URL")
}

/// Role defines user permissions and access tiers
/// Level: 1 = Super Admin, 2 = Supervisor, 3 = Staff, 4 = Non Staff, 5 = Guest
model Role {
  /// e.g., "ROL251117-0001"
  roleId       String    @id @db.NVarChar(20)
  roleName     String    @db.NVarChar(50)
  roleLevel    Int
  roleDesc     String?   @db.NVarChar(255)
  roleIsActive Boolean   @default(true)
  createdAt    DateTime  @default(now())
  /// references User.userId
  createdBy    String?   @db.NVarChar(20)
  updatedAt    DateTime  @updatedAt
  /// references User.userId
  updatedBy    String?   @db.NVarChar(20)
  isDeleted    Boolean   @default(false)
  deletedAt    DateTime?
  /// references User.userId
  deletedBy    String?   @db.NVarChar(20)
  creator      User?     @relation("RoleCreatedBy", fields: [createdBy], references: [userId], onDelete: NoAction, onUpdate: NoAction)
  deleter      User?     @relation("RoleDeletedBy", fields: [deletedBy], references: [userId], onDelete: NoAction, onUpdate: NoAction)
  updater      User?     @relation("RoleUpdatedBy", fields: [updatedBy], references: [userId], onDelete: NoAction, onUpdate: NoAction)
  users        User[]

  @@index([createdBy])
  @@index([updatedBy])
  @@index([deletedBy])
  @@map("roles")
}

/// User represents an authenticated individual in the system
model User {
  /// e.g., "USR251117-0001"
  userId       String    @id @db.NVarChar(20)
  username     String    @unique @db.NVarChar(30)
  /// bcrypt/scrypt hashed
  password     String    @db.NVarChar(100)
  name         String    @db.NVarChar(100)
  badgeNumber  String    @db.NVarChar(20)
  department   String?   @db.NVarChar(50)
  isActive     Boolean   @default(true)
  lastLogin    DateTime?
  createdAt    DateTime  @default(now())
  /// references User.userId
  createdBy    String?   @db.NVarChar(20)
  updatedAt    DateTime  @updatedAt
  /// references User.userId
  updatedBy    String?   @db.NVarChar(20)
  isDeleted    Boolean   @default(false)
  deletedAt    DateTime?
  /// references User.userId
  deletedBy    String?   @db.NVarChar(20)
  /// Role assignment
  roleId       String    @db.NVarChar(20)
  /// Optional auth token (e.g., refresh token)
  token        String?   @db.NVarChar(500)
  createdRoles Role[]    @relation("RoleCreatedBy")
  deletedRoles Role[]    @relation("RoleDeletedBy")
  updatedRoles Role[]    @relation("RoleUpdatedBy")
  creator      User?     @relation("UserCreatedBy", fields: [createdBy], references: [userId], onDelete: NoAction, onUpdate: NoAction)
  createdUsers User[]    @relation("UserCreatedBy")
  deleter      User?     @relation("UserDeletedBy", fields: [deletedBy], references: [userId], onDelete: NoAction, onUpdate: NoAction)
  deletedUsers User[]    @relation("UserDeletedBy")
  role         Role      @relation(fields: [roleId], references: [roleId])
  updater      User?     @relation("UserUpdatedBy", fields: [updatedBy], references: [userId], onDelete: NoAction, onUpdate: NoAction)
  updatedUsers User[]    @relation("UserUpdatedBy")

  @@index([username])
  @@index([badgeNumber])
  @@index([roleId])
  @@index([createdBy])
  @@index([updatedBy])
  @@index([deletedBy])
  @@map("users")
}

model Chart {
  /// e.g., "NODE251120-0001"
  chartId    String        @id @db.NVarChar(20)
  pilarId    Int
  sbuId      Int
  sbuSubId   Int
  /// NULL = posisi teratas (presiden)
  parentId   String?       @db.NVarChar(20)
  position   String        @db.NVarChar(100)
  capacity   Int           @default(1)
  /// urutan dalam satu level
  orderIndex Int           @default(0)
  createdAt  DateTime      @default(now())
  createdBy  String?       @db.NVarChar(20)
  updatedAt  DateTime      @updatedAt
  updatedBy  String?       @db.NVarChar(20)
  isDeleted  Boolean       @default(false)
  deletedAt  DateTime?
  deletedBy  String?       @db.NVarChar(20)
  jobDesc    String?       @db.NVarChar(500)
  parent     Chart?        @relation("ParentChild", fields: [parentId], references: [chartId], onDelete: NoAction, onUpdate: NoAction)
  children   Chart[]       @relation("ParentChild")
  members    ChartMember[]

  @@index([parentId])
  @@index([pilarId])
  @@index([sbuId])
  @@index([sbuSubId])
  @@map("chart")
}

model ChartMember {
  memberChartId String    @id @db.NVarChar(20)
  chartId       String    @db.NVarChar(20)
  userId        Int?
  createdAt     DateTime  @default(now())
  createdBy     String?   @db.NVarChar(20)
  updatedAt     DateTime  @updatedAt
  updatedBy     String?   @db.NVarChar(20)
  isDeleted     Boolean   @default(false)
  deletedAt     DateTime?
  deletedBy     String?   @db.NVarChar(20)
  jabatan       String?   @db.NVarChar(50)
  node          Chart     @relation(fields: [chartId], references: [chartId])

  @@index([chartId])
  @@index([userId])
  @@map("chart_member")
}

/// SOP master within Prosedur
model ProcedureSop {
  sopId         String           @id @db.NVarChar(20)
  sbuSubId      Int
  sbuId         Int?
  pilarId       Int?
  sopName       String           @db.NVarChar(150)
  sopNumber     String           @db.NVarChar(50)
  effectiveDate DateTime
  filePath      String           @db.NVarChar(500)
  fileName      String           @db.NVarChar(255)
  fileMime      String?          @db.NVarChar(100)
  fileSize      Int?
  isActive      Boolean          @default(true)
  isDeleted     Boolean          @default(false)
  createdAt     DateTime         @default(now())
  createdBy     String?          @db.NVarChar(20)
  updatedAt     DateTime         @updatedAt
  updatedBy     String?          @db.NVarChar(20)
  deletedAt     DateTime?
  deletedBy     String?          @db.NVarChar(20)
  masterIKs     ProcedureSopIK[]

  @@index([sbuSubId, isActive, isDeleted])
  @@index([sbuId])
  @@index([pilarId])
  @@index([sopNumber])
  @@map("procedure_sop")
}

/// Master IK shared across SOPs
model MasterIK {
  ikId          String           @id @db.NVarChar(20)
  ikName        String           @db.NVarChar(150)
  ikNumber      String           @db.NVarChar(50)
  effectiveDate DateTime
  ikContent     String?          @db.NVarChar(Max)
  dibuatOleh    Int?
  diketahuiOleh Int?
  disetujuiOleh Int?
  isActive      Boolean          @default(true)
  isDeleted     Boolean          @default(false)
  createdAt     DateTime         @default(now())
  createdBy     String?          @db.NVarChar(20)
  updatedAt     DateTime         @updatedAt
  updatedBy     String?          @db.NVarChar(20)
  deletedAt     DateTime?
  deletedBy     String?          @db.NVarChar(20)
  sops          ProcedureSopIK[]

  @@index([ikNumber])
  @@map("master_ik")
}

/// SOP to Master IK join table
model ProcedureSopIK {
  sopIkId   String       @id @db.NVarChar(20)
  sopId     String       @db.NVarChar(20)
  ikId      String       @db.NVarChar(20)
  isActive  Boolean      @default(true)
  isDeleted Boolean      @default(false)
  createdAt DateTime     @default(now())
  createdBy String?      @db.NVarChar(20)
  updatedAt DateTime     @updatedAt
  updatedBy String?      @db.NVarChar(20)
  deletedAt DateTime?
  deletedBy String?      @db.NVarChar(20)
  sop       ProcedureSop @relation(fields: [sopId], references: [sopId], onDelete: NoAction, onUpdate: NoAction)
  masterIK  MasterIK     @relation(fields: [ikId], references: [ikId], onDelete: NoAction, onUpdate: NoAction)

  @@index([sopId, isActive, isDeleted])
  @@index([ikId, isActive, isDeleted])
  @@map("procedure_sop_ik")
}

/// Case header (problem/project)
model CaseHeader {
  /// e.g., "CAS260211-0001"
  caseId                       String                    @id @db.NVarChar(20)
  caseType                     String                    @db.NVarChar(20)
  caseTitle                    String                    @db.NVarChar(200)
  background                   String?                   @db.NVarChar(1000)
  currentCondition             String?                   @db.NVarChar(2000)
  projectDesc                  String?                   @db.NVarChar(2000)
  projectObjective             String?                   @db.NVarChar(1000)
  locationDesc                 String?                   @db.NVarChar(255)
  notes                        String?                   @db.NVarChar(1000)
  status                       String                    @default("NEW") @db.NVarChar(20)
  visibility                   String                    @default("PRIVATE") @db.NVarChar(20)
  requesterId                  String?                   @db.NVarChar(20)
  requesterEmployeeId          Int?
  originSbuSubId               Int?
  feedbackApprovedAt           DateTime?
  feedbackApprovedBy           String?                   @db.NVarChar(20)
  feedbackApprovedByEmployeeId Int?
  isActive                     Boolean                   @default(true)
  createdAt                    DateTime                  @default(now())
  createdBy                    String?                   @db.NVarChar(20)
  updatedAt                    DateTime                  @updatedAt
  updatedBy                    String?                   @db.NVarChar(20)
  isDeleted                    Boolean                   @default(false)
  deletedAt                    DateTime?
  deletedBy                    String?                   @db.NVarChar(20)
  departments                  CaseDepartment[]
  attachments                  CaseAttachment[]
  caseFishbones                CaseFishboneMaster[]
  casePdcaItems                CasePdcaItem[]
  caseFeedbackComments         CaseFeedbackComment[]
  notifications                CaseNotificationOutbox[]
  caseNotificationMessages     CaseNotificationMessage[]

  @@index([status])
  @@index([requesterId])
  @@index([requesterEmployeeId])
  @@index([originSbuSubId])
  @@map("case_header")
}

/// Case -> target departments (SBU sub) with decision + PIC assignment
model CaseDepartment {
  caseDepartmentId         String                    @id @db.NVarChar(20)
  caseId                   String                    @db.NVarChar(20)
  sbuSubId                 Int
  decisionStatus           String                    @default("PENDING") @db.NVarChar(20)
  decisionAt               DateTime?
  decisionBy               String?                   @db.NVarChar(20)
  decisionNotes            String?                   @db.NVarChar(500)
  assigneeEmployeeId       Int?
  assignedAt               DateTime?
  assignedBy               String?                   @db.NVarChar(20)
  workStatus               String?                   @db.NVarChar(20)
  startDate                DateTime?
  targetDate               DateTime?
  endDate                  DateTime?
  workNotes                String?                   @db.NVarChar(500)
  isActive                 Boolean                   @default(true)
  createdAt                DateTime                  @default(now())
  createdBy                String?                   @db.NVarChar(20)
  updatedAt                DateTime                  @updatedAt
  updatedBy                String?                   @db.NVarChar(20)
  isDeleted                Boolean                   @default(false)
  deletedAt                DateTime?
  deletedBy                String?                   @db.NVarChar(20)
  case                     CaseHeader                @relation(fields: [caseId], references: [caseId], onDelete: NoAction, onUpdate: NoAction)
  assignees                CaseDepartmentAssignee[]
  notifications            CaseNotificationOutbox[]
  caseNotificationMessages CaseNotificationMessage[]

  @@unique([caseId, sbuSubId])
  @@index([caseId, decisionStatus])
  @@index([sbuSubId])
  @@map("case_department")
}

model CaseDepartmentAssignee {
  caseDepartmentAssigneeId String         @id @db.NVarChar(20)
  caseDepartmentId         String         @db.NVarChar(20)
  employeeId               Int
  assignedAt               DateTime?
  assignedBy               String?        @db.NVarChar(20)
  isActive                 Boolean        @default(true)
  createdAt                DateTime       @default(now())
  createdBy                String?        @db.NVarChar(20)
  updatedAt                DateTime       @updatedAt
  updatedBy                String?        @db.NVarChar(20)
  isDeleted                Boolean        @default(false)
  deletedAt                DateTime?
  deletedBy                String?        @db.NVarChar(20)
  department               CaseDepartment @relation(fields: [caseDepartmentId], references: [caseDepartmentId], onDelete: NoAction, onUpdate: NoAction)

  @@unique([caseDepartmentId, employeeId])
  @@index([caseDepartmentId])
  @@index([employeeId])
  @@map("case_department_assignee")
}

/// Case notification outbox (WhatsApp, etc.)
model CaseNotificationOutbox {
  caseNotificationId  String          @id @db.NVarChar(20)
  caseId              String?         @db.NVarChar(20)
  caseDepartmentId    String?         @db.NVarChar(20)
  recipientEmployeeId Int?
  channel             String          @db.NVarChar(20)
  phoneNumber         String          @db.NVarChar(20)
  message             String          @db.NVarChar(1000)
  status              String          @default("PENDING") @db.NVarChar(20)
  attempts            Int             @default(0)
  lastError           String?         @db.NVarChar(500)
  provider            String?         @db.NVarChar(50)
  meta                String?         @db.NVarChar(Max)
  isActive            Boolean         @default(true)
  createdAt           DateTime        @default(now())
  createdBy           String?         @db.NVarChar(20)
  updatedAt           DateTime        @updatedAt
  updatedBy           String?         @db.NVarChar(20)
  isDeleted           Boolean         @default(false)
  deletedAt           DateTime?
  deletedBy           String?         @db.NVarChar(20)
  case                CaseHeader?     @relation(fields: [caseId], references: [caseId], onDelete: NoAction, onUpdate: NoAction)
  department          CaseDepartment? @relation(fields: [caseDepartmentId], references: [caseDepartmentId], onDelete: NoAction, onUpdate: NoAction)

  @@index([caseId])
  @@index([caseDepartmentId])
  @@index([status, isDeleted])
  @@map("case_notification_outbox")
}

/// Custom notification message template (per case/person/role)
model CaseNotificationMessage {
  caseNotificationMessageId String          @id @db.NVarChar(20)
  caseId                    String?         @db.NVarChar(20)
  caseDepartmentId          String?         @db.NVarChar(20)
  recipientEmployeeId       Int?
  role                      String          @db.NVarChar(20)
  messageTemplate           String          @db.NVarChar(1000)
  isActive                  Boolean         @default(true)
  createdAt                 DateTime        @default(now())
  createdBy                 String?         @db.NVarChar(20)
  updatedAt                 DateTime        @updatedAt
  updatedBy                 String?         @db.NVarChar(20)
  isDeleted                 Boolean         @default(false)
  deletedAt                 DateTime?
  deletedBy                 String?         @db.NVarChar(20)
  case                      CaseHeader?     @relation(fields: [caseId], references: [caseId], onDelete: NoAction, onUpdate: NoAction)
  department                CaseDepartment? @relation(fields: [caseDepartmentId], references: [caseDepartmentId], onDelete: NoAction, onUpdate: NoAction)

  @@index([caseId])
  @@index([caseDepartmentId])
  @@index([recipientEmployeeId, role])
  @@map("case_notification_message")
}

/// Default notification template for outbox
model CaseNotificationTemplate {
  caseNotificationTemplateId String    @id @db.NVarChar(20)
  templateName               String    @db.NVarChar(100)
  channel                    String    @db.NVarChar(20)
  role                       String    @db.NVarChar(20)
  action                     String?   @db.NVarChar(30)
  caseType                   String?   @db.NVarChar(20)
  messageTemplate            String    @db.NVarChar(1000)
  isActive                   Boolean   @default(true)
  createdAt                  DateTime  @default(now())
  createdBy                  String?   @db.NVarChar(20)
  updatedAt                  DateTime  @updatedAt
  updatedBy                  String?   @db.NVarChar(20)
  isDeleted                  Boolean   @default(false)
  deletedAt                  DateTime?
  deletedBy                  String?   @db.NVarChar(20)

  @@index([channel, role, action, caseType, isActive, isDeleted])
  @@map("case_notification_template")
}

/// Generic notification template for OMS portal notifications
model NotificationTemplate {
  notificationTemplateId String                       @id @db.NVarChar(20)
  templateName           String                       @db.NVarChar(100)
  channel                String                       @db.NVarChar(20)
  eventKey               String                       @db.NVarChar(50)
  recipientRole          String                       @db.NVarChar(30)
  messageTemplate        String                       @db.NVarChar(1000)
  isActive               Boolean                      @default(true)
  createdAt              DateTime                     @default(now())
  createdBy              String?                      @db.NVarChar(20)
  updatedAt              DateTime                     @updatedAt
  updatedBy              String?                      @db.NVarChar(20)
  isDeleted              Boolean                      @default(false)
  deletedAt              DateTime?
  deletedBy              String?                      @db.NVarChar(20)
  portalMappings         NotificationTemplatePortal[]
  outboxes               NotificationOutbox[]

  @@index([channel, eventKey, recipientRole, isActive, isDeleted])
  @@map("notification_template")
}

/// Portal mapping for generic OMS notification templates
model NotificationTemplatePortal {
  notificationTemplatePortalId String               @id @db.NVarChar(20)
  notificationTemplateId       String               @db.NVarChar(20)
  portalKey                    String               @db.NVarChar(50)
  isActive                     Boolean              @default(true)
  createdAt                    DateTime             @default(now())
  createdBy                    String?              @db.NVarChar(20)
  updatedAt                    DateTime             @updatedAt
  updatedBy                    String?              @db.NVarChar(20)
  isDeleted                    Boolean              @default(false)
  deletedAt                    DateTime?
  deletedBy                    String?              @db.NVarChar(20)
  template                     NotificationTemplate @relation(fields: [notificationTemplateId], references: [notificationTemplateId], onDelete: NoAction, onUpdate: NoAction)

  @@unique([notificationTemplateId, portalKey, isDeleted])
  @@index([notificationTemplateId, isDeleted, isActive])
  @@index([portalKey, isDeleted, isActive])
  @@map("notification_template_portal")
}

/// Generic notification outbox for OMS portals
model NotificationOutbox {
  notificationOutboxId   String                @id @db.NVarChar(20)
  notificationTemplateId String?               @db.NVarChar(20)
  portalKey              String                @db.NVarChar(50)
  eventKey               String                @db.NVarChar(50)
  recipientRole          String?               @db.NVarChar(30)
  recipientReferenceType String?               @db.NVarChar(50)
  recipientReferenceId   String?               @db.NVarChar(100)
  contextReferenceType   String?               @db.NVarChar(50)
  contextReferenceId     String?               @db.NVarChar(100)
  phoneNumber            String                @db.NVarChar(30)
  message                String                @db.NVarChar(1000)
  status                 String                @default("PENDING") @db.NVarChar(20)
  attempts               Int                   @default(0)
  lastError              String?               @db.NVarChar(500)
  provider               String?               @db.NVarChar(50)
  sentAt                 DateTime?
  meta                   String?               @db.NVarChar(Max)
  isActive               Boolean               @default(true)
  createdAt              DateTime              @default(now())
  createdBy              String?               @db.NVarChar(20)
  updatedAt              DateTime              @updatedAt
  updatedBy              String?               @db.NVarChar(20)
  isDeleted              Boolean               @default(false)
  deletedAt              DateTime?
  deletedBy              String?               @db.NVarChar(20)
  template               NotificationTemplate? @relation(fields: [notificationTemplateId], references: [notificationTemplateId], onDelete: NoAction, onUpdate: NoAction)

  @@index([notificationTemplateId])
  @@index([portalKey, eventKey, isDeleted, isActive])
  @@index([recipientReferenceType, recipientReferenceId, isDeleted])
  @@index([contextReferenceType, contextReferenceId, isDeleted])
  @@index([status, isDeleted])
  @@map("notification_outbox")
}

/// Case attachments (photo/video documentation)
model CaseAttachment {
  caseAttachmentId String     @id @db.NVarChar(20)
  caseId           String     @db.NVarChar(20)
  mediaType        String     @db.NVarChar(10)
  filePath         String     @db.NVarChar(500)
  fileName         String     @db.NVarChar(255)
  fileMime         String?    @db.NVarChar(100)
  fileSize         Int?
  caption          String?    @db.NVarChar(255)
  locationDesc     String?    @db.NVarChar(255)
  orderIndex       Int        @default(0)
  isActive         Boolean    @default(true)
  createdAt        DateTime   @default(now())
  createdBy        String?    @db.NVarChar(20)
  updatedAt        DateTime   @updatedAt
  updatedBy        String?    @db.NVarChar(20)
  isDeleted        Boolean    @default(false)
  deletedAt        DateTime?
  deletedBy        String?    @db.NVarChar(20)
  case             CaseHeader @relation(fields: [caseId], references: [caseId], onDelete: NoAction, onUpdate: NoAction)

  @@index([caseId, isDeleted])
  @@map("case_attachment")
}

/// Fishbone master
model MasterFishbone {
  fishboneId   String          @id @db.NVarChar(20)
  sbuSubId     Int
  fishboneName String          @db.NVarChar(150)
  fishboneDesc String?         @db.NVarChar(1000)
  isActive     Boolean         @default(true)
  createdAt    DateTime        @default(now())
  createdBy    String?         @db.NVarChar(20)
  updatedAt    DateTime        @updatedAt
  updatedBy    String?         @db.NVarChar(20)
  isDeleted    Boolean         @default(false)
  deletedAt    DateTime?
  deletedBy    String?         @db.NVarChar(20)
  causes       FishboneCause[]
  items        FishboneItem[]

  @@index([sbuSubId, isActive, isDeleted])
  @@map("master_fishbone")
}

/// Case fishbone header (per case)
model CaseFishboneMaster {
  caseFishboneId String              @id @db.NVarChar(20)
  caseId         String              @db.NVarChar(20)
  sbuSubId       Int
  fishboneName   String              @db.NVarChar(150)
  fishboneDesc   String?             @db.NVarChar(1000)
  isActive       Boolean             @default(true)
  createdAt      DateTime            @default(now())
  createdBy      String?             @db.NVarChar(20)
  updatedAt      DateTime            @updatedAt
  updatedBy      String?             @db.NVarChar(20)
  isDeleted      Boolean             @default(false)
  deletedAt      DateTime?
  deletedBy      String?             @db.NVarChar(20)
  case_header    CaseHeader          @relation(fields: [caseId], references: [caseId], onDelete: NoAction, onUpdate: NoAction)
  causes         CaseFishboneCause[]
  items          CaseFishboneItem[]

  @@index([caseId, isActive, isDeleted])
  @@index([sbuSubId])
  @@map("case_fishbone_master")
}

/// Case fishbone root causes
model CaseFishboneCause {
  caseFishboneCauseId String                  @id @db.NVarChar(20)
  caseFishboneId      String                  @db.NVarChar(20)
  causeNo             Int
  causeText           String                  @db.NVarChar(1000)
  isActive            Boolean                 @default(true)
  createdAt           DateTime                @default(now())
  createdBy           String?                 @db.NVarChar(20)
  updatedAt           DateTime                @updatedAt
  updatedBy           String?                 @db.NVarChar(20)
  isDeleted           Boolean                 @default(false)
  deletedAt           DateTime?
  deletedBy           String?                 @db.NVarChar(20)
  case_fishbone       CaseFishboneMaster      @relation(fields: [caseFishboneId], references: [caseFishboneId], onDelete: NoAction, onUpdate: NoAction)
  itemLinks           CaseFishboneItemCause[]

  @@unique([caseFishboneId, causeNo])
  @@index([caseFishboneId, isActive, isDeleted])
  @@map("case_fishbone_cause")
}

/// Case fishbone problem + solution per category (6M)
model CaseFishboneItem {
  caseFishboneItemId String                  @id @db.NVarChar(20)
  caseFishboneId     String                  @db.NVarChar(20)
  categoryCode       String                  @db.NVarChar(20)
  problemText        String                  @db.NVarChar(1000)
  solutionText       String                  @db.NVarChar(1000)
  isActive           Boolean                 @default(true)
  createdAt          DateTime                @default(now())
  createdBy          String?                 @db.NVarChar(20)
  updatedAt          DateTime                @updatedAt
  updatedBy          String?                 @db.NVarChar(20)
  isDeleted          Boolean                 @default(false)
  deletedAt          DateTime?
  deletedBy          String?                 @db.NVarChar(20)
  case_fishbone      CaseFishboneMaster      @relation(fields: [caseFishboneId], references: [caseFishboneId], onDelete: NoAction, onUpdate: NoAction)
  category           FishboneCategory        @relation(fields: [categoryCode], references: [categoryCode], onDelete: NoAction, onUpdate: NoAction)
  causeLinks         CaseFishboneItemCause[]

  @@index([caseFishboneId, categoryCode])
  @@index([caseFishboneId, isActive, isDeleted])
  @@map("case_fishbone_item")
}

/// Case fishbone item to cause mapping
model CaseFishboneItemCause {
  caseFishboneItemCauseId String            @id @db.NVarChar(20)
  caseFishboneItemId      String            @db.NVarChar(20)
  caseFishboneCauseId     String            @db.NVarChar(20)
  isActive                Boolean           @default(true)
  createdAt               DateTime          @default(now())
  createdBy               String?           @db.NVarChar(20)
  updatedAt               DateTime          @updatedAt
  updatedBy               String?           @db.NVarChar(20)
  isDeleted               Boolean           @default(false)
  deletedAt               DateTime?
  deletedBy               String?           @db.NVarChar(20)
  item                    CaseFishboneItem  @relation(fields: [caseFishboneItemId], references: [caseFishboneItemId], onDelete: NoAction, onUpdate: NoAction)
  cause                   CaseFishboneCause @relation(fields: [caseFishboneCauseId], references: [caseFishboneCauseId], onDelete: NoAction, onUpdate: NoAction)

  @@unique([caseFishboneItemId, caseFishboneCauseId])
  @@index([caseFishboneItemId, isActive, isDeleted])
  @@index([caseFishboneCauseId, isActive, isDeleted])
  @@map("case_fishbone_item_cause")
}

